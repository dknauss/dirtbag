{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Brutalist",
  "settings": {
    "appearanceTools": false,
    "color": {
      "custom": true,
      "customDuotone": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "name": "Black",
          "slug": "black",
          "color": "#000000"
        },
        {
          "name": "White",
          "slug": "white",
          "color": "#ffffff"
        },
        {
          "name": "Grey 20",
          "slug": "gray-20",
          "color": "#333333"
        },
        {
          "name": "Grey 40",
          "slug": "gray-40",
          "color": "#666666"
        },
        {
          "name": "Grey 60",
          "slug": "gray-60",
          "color": "#999999"
        },
        {
          "name": "Grey 80",
          "slug": "gray-80",
          "color": "#cccccc"
        },
        {
          "name": "Red",
          "slug": "red",
          "color": "#ff0000"
        },
        {
          "name": "Maroon",
          "slug": "maroon",
          "color": "#990000"
        },
        {
          "name": "Orange",
          "slug": "orange",
          "color": "#ff9900"
        },
        {
          "name": "Yellow",
          "slug": "yellow",
          "color": "#ffff00"
        },
        {
          "name": "Olive",
          "slug": "olive",
          "color": "#999900"
        },
        {
          "name": "Lime",
          "slug": "lime",
          "color": "#00ff00"
        },
        {
          "name": "Green",
          "slug": "green",
          "color": "#009900"
        },
        {
          "name": "Aqua",
          "slug": "aqua",
          "color": "#00ffff"
        },
        {
          "name": "Teal",
          "slug": "teal",
          "color": "#009999"
        },
        {
          "name": "Blue",
          "slug": "blue",
          "color": "#0000ff"
        },
        {
          "name": "Navy",
          "slug": "navy",
          "color": "#000099"
        },
        {
          "name": "Fuchsia",
          "slug": "fuchsia",
          "color": "#ff00ff"
        },
        {
          "name": "Purple",
          "slug": "purple",
          "color": "#990099"
        }
      ]
    },
    "spacing": {
      "customSpacingSize": true,
      "spacingSizes": [],
      "units": [
        "px",
        "em",
        "rem",
        "%",
        "vw",
        "vh"
      ]
    },
    "typography": {
      "customFontSize": true,
      "fluid": false,
      "fontFamilies": [
        {
          "name": "Arial",
          "slug": "arial",
          "fontFamily": "Arial, Helvetica, sans-serif"
        },
        {
          "name": "Arial Black",
          "slug": "arial-black",
          "fontFamily": "'Arial Black', Gadget, sans-serif"
        },
        {
          "name": "Comic Sans MS",
          "slug": "comic-sans-ms",
          "fontFamily": "'Comic Sans MS', cursive, sans-serif"
        },
        {
          "name": "Courier New",
          "slug": "courier-new",
          "fontFamily": "'Courier New', Courier, monospace"
        },
        {
          "name": "Georgia",
          "slug": "georgia",
          "fontFamily": "Georgia, serif"
        },
        {
          "name": "Impact",
          "slug": "impact",
          "fontFamily": "Impact, Charcoal, sans-serif"
        },
        {
          "name": "Lucida Console",
          "slug": "lucida-console",
          "fontFamily": "'Lucida Console', Monaco, monospace"
        },
        {
          "name": "Lucida Sans Unicode",
          "slug": "lucida-sans-unicode",
          "fontFamily": "'Lucida Sans Unicode', 'Lucida Grande', sans-serif"
        },
        {
          "name": "Palatino",
          "slug": "palatino",
          "fontFamily": "'Palatino Linotype', 'Book Antiqua', Palatino, serif"
        },
        {
          "name": "Tahoma",
          "slug": "tahoma",
          "fontFamily": "Tahoma, Geneva, sans-serif"
        },
        {
          "name": "Times New Roman",
          "slug": "times-new-roman",
          "fontFamily": "'Times New Roman', Times, serif"
        },
        {
          "name": "Trebuchet MS",
          "slug": "trebuchet-ms",
          "fontFamily": "'Trebuchet MS', Helvetica, sans-serif"
        },
        {
          "name": "Verdana",
          "slug": "verdana",
          "fontFamily": "Verdana, Geneva, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "fluid": false,
          "name": "Small",
          "size": "15px",
          "slug": "small"
        },
        {
          "fluid": false,
          "name": "Base",
          "size": "18px",
          "slug": "base"
        },
        {
          "fluid": false,
          "name": "Medium",
          "size": "22px",
          "slug": "medium"
        },
        {
          "fluid": false,
          "name": "Large",
          "size": "28px",
          "slug": "large"
        },
        {
          "fluid": false,
          "name": "Extra Large",
          "size": "36px",
          "slug": "x-large"
        },
        {
          "fluid": false,
          "name": "Huge",
          "size": "48px",
          "slug": "huge"
        }
      ]
    },
    "useRootPaddingAwareAlignments": false,
    "layout": {
      "contentSize": "42rem",
      "wideSize": "64rem"
    },
    "custom": {
      "dirtbag": {
        "truckIconFilter": "none"
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ],
  "styles": {
    "spacing": {
      "padding": {
        "top": "24px",
        "right": "24px",
        "bottom": "24px",
        "left": "24px"
      },
      "blockGap": "1.4em"
    },
    "typography": {
      "fontSize": "18px",
      "lineHeight": "1.4"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontSize": "36px",
          "lineHeight": "1.15"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "28px",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "22px",
          "lineHeight": "1.25"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "20px",
          "lineHeight": "1.3"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "18px",
          "lineHeight": "1.35"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "15px",
          "lineHeight": "1.35"
        }
      },
      "button": {
        "border": {
          "radius": "0"
        },
        ":hover": {
          "border": {
            "radius": "0"
          }
        },
        ":focus": {
          "border": {
            "radius": "0"
          }
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontSize": "48px",
          "fontWeight": "700",
          "lineHeight": "1.05"
        },
        "spacing": {
          "margin": {
            "bottom": "0"
          }
        }
      },
      "core/site-tagline": {
        "typography": {
          "fontSize": "18px",
          "lineHeight": "1.3",
          "fontStyle": "italic"
        },
        "spacing": {
          "margin": {
            "top": "0"
          }
        }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "36px",
          "fontWeight": "700",
          "lineHeight": "1.15"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "18px",
          "lineHeight": "1.3"
        }
      },
      "core/button": {
        "border": {
          "radius": "0"
        },
        "elements": {
          "link": {
            "border": {
              "radius": "0"
            }
          }
        }
      }
    },
    "css": ".wp-block-group.byline { gap: 0 !important; }\n.wp-block-group.byline > p,\n.wp-block-group.byline > .wp-block-post-author-name { margin-top: 0; margin-bottom: 0; }\n.wp-block-site-logo img,\n.wp-block-navigation .wp-block-site-logo img,\n.custom-logo,\n.h-card img.u-photo { filter: var(--wp--custom--dirtbag--truck-icon-filter, none); background: transparent; }\n"
  },
  "customTemplates": [
    {
      "name": "page-no-title",
      "title": "No title page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-wide",
      "title": "Wide page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-centered",
      "title": "Centred page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-plain",
      "title": "Plain page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-colophon",
      "title": "Colophon page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-now",
      "title": "Now page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-links",
      "title": "Links page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-feeds",
      "title": "Feeds page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-uses",
      "title": "Uses page",
      "postTypes": [
        "page"
      ]
    }
  ]
}
