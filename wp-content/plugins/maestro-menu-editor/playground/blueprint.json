{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Maestro — role-testing demo",
		"author": "dknauss",
		"description": "In-place admin menu editor, plus User Switching and test users (editor, author, contributor, subscriber) for trying per-role menu visibility."
	},
	"landingPage": "/wp-admin/index.php?maestro_edit=1",
	"preferredVersions": { "php": "8.3", "wp": "latest" },
	"login": true,
	"plugins": [ "user-switching" ],
	"steps": [
		{
			"step": "wp-cli",
			"command": "wp user create editor editor@example.com --role=editor --user_pass=password",
			"progress": { "caption": "Creating an editor" }
		},
		{
			"step": "wp-cli",
			"command": "wp user create author author@example.com --role=author --user_pass=password",
			"progress": { "caption": "Creating an author" }
		},
		{
			"step": "wp-cli",
			"command": "wp user create contributor contributor@example.com --role=contributor --user_pass=password",
			"progress": { "caption": "Creating a contributor" }
		},
		{
			"step": "wp-cli",
			"command": "wp user create subscriber subscriber@example.com --role=subscriber --user_pass=password",
			"progress": { "caption": "Creating a subscriber" }
		},
		{
			"step": "wp-cli",
			"command": "wp plugin activate maestro-menu-editor/maestro-menu-editor.php",
			"progress": { "caption": "Activating Maestro" }
		}
	]
}
