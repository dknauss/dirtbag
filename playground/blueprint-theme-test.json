{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/",
  "meta": {
    "title": "Dirtbag Theme — Theme Unit Test Data",
    "author": "Dan Knauss",
    "description": "Boot the released Dirtbag theme (v0.1.3) and import the official WordPress Theme Unit Test data for review. Throwaway environment; does not touch the authoring site.",
    "categories": [
      "theme",
      "block-theme"
    ]
  },
  "preferredVersions": {
    "php": "8.3",
    "wp": "latest"
  },
  "login": true,
  "steps": [
    {
      "step": "installTheme",
      "themeData": {
        "resource": "git:directory",
        "url": "https://github.com/dknauss/dirtbag",
        "ref": "cf70cb5b65ab854f19433b7224bfcf187d01d7e7",
        "refType": "commit",
        "path": "/"
      },
      "options": {
        "activate": true,
        "importStarterContent": false,
        "targetFolderName": "dirtbag"
      },
      "ifAlreadyInstalled": "overwrite"
    },
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "Dirtbag — Theme Unit Test",
        "blogdescription": "Official WordPress Theme Unit Test content."
      }
    },
    {
      "step": "importWxr",
      "file": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/WPTT/theme-test-data/master/themeunittestdata.wordpress.xml"
      }
    }
  ]
}
