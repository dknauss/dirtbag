+	/**
+	 * Test low-level wptexturize_replace_xxx routines.
+	 * @ticket wptexturize_replace_xxx
+	 */
+	function test_wptexturize_replace() {
+		$orig_str = '<a href="#">0<abbr>1</abbr></a>2<b>2</b>345<big>5</big>6<br>77<dfn></em>8<i><samp>9</samp>A<small>B</small>CDE<span></span>F<strong>G</sub>[H<sup>]<var>I</var>';
+
+		$str = $orig_str;
+		wptexturize_replace_init( $str, '/<[^>]*>|\[H[^\]]*\]/' );
+		$this->assertEquals( '0122345567789ABCDEFGI', $str );
+
+		wptexturize_replace_final( $str );
+		$this->assertEquals( $orig_str, $str );
+
+		wptexturize_replace_init( $str, '/<[^>]*>|\[H[^\]]*\]/' );
+		$this->assertEquals( '0122345567789ABCDEFGI', $str );
+
+		wptexturize_replace_str( $str, '5', 'EF' );
+		$this->assertEquals( '012234EFEF67789ABCDEFGI', $str );
+
+		wptexturize_replace_regex( $str, '/2/', '2BB2' );
+		$this->assertEquals( '012BB22BB234EFEF67789ABCDEFGI', $str );
+
+		wptexturize_replace_regex( $str, '/(3)4/', '$1FOUR' );
+		$this->assertEquals( '012BB22BB23FOUREFEF67789ABCDEFGI', $str );
+
+		wptexturize_replace_str( $str, '8', 'B' );
+		$this->assertEquals( '012BB22BB23FOUREFEF677B9ABCDEFGI', $str );
+
+		wptexturize_replace_regex( $str, '/7/', '7EFEN' );
+		$this->assertEquals( '012BB22BB23FOUREFEF67EFEN7EFENB9ABCDEFGI', $str );
+
+		wptexturize_replace_str( $str, '6', '666' );
+		$this->assertEquals( '012BB22BB23FOUREFEF6667EFEN7EFENB9ABCDEFGI', $str );
+
+		wptexturize_replace_str( $str, '1', '12' );
+		$this->assertEquals( '0122BB22BB23FOUREFEF6667EFEN7EFENB9ABCDEFGI', $str );
+
+		wptexturize_replace_str( $str, 'BC', 'BCBC' );
+		$this->assertEquals( '0122BB22BB23FOUREFEF6667EFEN7EFENB9ABCBCDEFGI', $str );
+
+		wptexturize_replace_regex( $str, '/3(FO)U/', 'THREE$1EWE' );
+		$this->assertEquals( '0122BB22BB2THREEFOEWEREFEF6667EFEN7EFENB9ABCBCDEFGI', $str );
+
+		wptexturize_replace_regex( $str, '/(E)F/', '$1' );
+		$this->assertEquals( '0122BB22BB2THREEOEWEREE6667EEN7EENB9ABCBCDEGI', $str );
+
+		wptexturize_replace_regex( $str, '/G/', '' );
+		$this->assertEquals( '0122BB22BB2THREEOEWEREE6667EEN7EENB9ABCBCDEI', $str );
+
+		wptexturize_replace_final( $str );
+		$this->assertEquals( '<a href="#">0<abbr>12</abbr></a>2BB2<b>2BB2</b>THREEOEWERE<big>E</big>666<br>7EEN7EEN<dfn></em>B<i><samp>9</samp>A<small>BCBC</small>DE<span></span><strong></sub>[H<sup>]<var>I</var>', $str );
+	}
+}
