{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Blueprint",
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "name": "Blueprint",
          "slug": "blueprint",
          "color": "#000099"
        },
        {
          "name": "Line",
          "slug": "line",
          "color": "#ffffff"
        },
        {
          "name": "Cyan",
          "slug": "cyan",
          "color": "#00ffff"
        },
        {
          "name": "Shadow",
          "slug": "shadow",
          "color": "#000000"
        }
      ]
    },
    "layout": {
      "contentSize": "42rem",
      "wideSize": "64rem"
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 4,
        "mediumStep": 1.5,
        "unit": "rem"
      }
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Arial",
          "slug": "arial",
          "fontFamily": "Arial, Helvetica, sans-serif"
        },
        {
          "name": "Arial Black",
          "slug": "arial-black",
          "fontFamily": "'Arial Black', Gadget, sans-serif"
        },
        {
          "name": "Comic Sans MS",
          "slug": "comic-sans-ms",
          "fontFamily": "'Comic Sans MS', cursive, sans-serif"
        },
        {
          "name": "Courier New",
          "slug": "courier-new",
          "fontFamily": "'Courier New', Courier, monospace"
        },
        {
          "name": "Georgia",
          "slug": "georgia",
          "fontFamily": "Georgia, serif"
        },
        {
          "name": "Impact",
          "slug": "impact",
          "fontFamily": "Impact, Charcoal, sans-serif"
        },
        {
          "name": "Lucida Console",
          "slug": "lucida-console",
          "fontFamily": "'Lucida Console', Monaco, monospace"
        },
        {
          "name": "Lucida Sans Unicode",
          "slug": "lucida-sans-unicode",
          "fontFamily": "'Lucida Sans Unicode', 'Lucida Grande', sans-serif"
        },
        {
          "name": "Palatino",
          "slug": "palatino",
          "fontFamily": "'Palatino Linotype', 'Book Antiqua', Palatino, serif"
        },
        {
          "name": "Tahoma",
          "slug": "tahoma",
          "fontFamily": "Tahoma, Geneva, sans-serif"
        },
        {
          "name": "Times New Roman",
          "slug": "times-new-roman",
          "fontFamily": "'Times New Roman', Times, serif"
        },
        {
          "name": "Trebuchet MS",
          "slug": "trebuchet-ms",
          "fontFamily": "'Trebuchet MS', Helvetica, sans-serif"
        },
        {
          "name": "Verdana",
          "slug": "verdana",
          "fontFamily": "Verdana, Geneva, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "fluid": false,
          "name": "Small",
          "size": "15px",
          "slug": "small"
        },
        {
          "fluid": false,
          "name": "Base",
          "size": "18px",
          "slug": "base"
        },
        {
          "fluid": false,
          "name": "Medium",
          "size": "22px",
          "slug": "medium"
        },
        {
          "fluid": false,
          "name": "Large",
          "size": "28px",
          "slug": "large"
        },
        {
          "fluid": false,
          "name": "Extra Large",
          "size": "36px",
          "slug": "x-large"
        },
        {
          "fluid": false,
          "name": "Huge",
          "size": "48px",
          "slug": "huge"
        }
      ],
      "fluid": false
    },
    "custom": {
      "dirtbag": {
        "truckIconFilter": "brightness(0) saturate(100%) invert(64%) sepia(85%) saturate(1800%) hue-rotate(360deg) brightness(103%) contrast(105%)"
      }
    }
  },
  "styles": {
    "color": {
      "background": "#000099",
      "text": "#ffffff"
    },
    "elements": {
      "button": {
        "border": {
          "color": "#00ffff",
          "style": "solid",
          "width": "1px",
          "radius": "0"
        },
        "color": {
          "background": "#000099",
          "text": "#ffffff"
        },
        "spacing": {
          "padding": {
            "bottom": "0.5rem",
            "left": "0.75rem",
            "right": "0.75rem",
            "top": "0.5rem"
          }
        },
        ":hover": {
          "border": {
            "radius": "0"
          }
        },
        ":focus": {
          "border": {
            "radius": "0"
          }
        }
      },
      "caption": {
        "color": {
          "text": "#00ffff"
        },
        "typography": {
          "fontSize": "0.875rem"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "36px",
          "lineHeight": "1.15"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "28px",
          "lineHeight": "1.2"
        }
      },
      "link": {
        "color": {
          "text": "#00ffff"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "22px",
          "lineHeight": "1.25"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "20px",
          "lineHeight": "1.3"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "18px",
          "lineHeight": "1.35"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "15px",
          "lineHeight": "1.35"
        }
      }
    },
    "spacing": {
      "blockGap": "1rem",
      "padding": {
        "bottom": "2rem",
        "left": "1rem",
        "right": "1rem",
        "top": "2rem"
      }
    },
    "typography": {
      "fontFamily": "'Trebuchet MS', Helvetica, sans-serif",
      "fontSize": "18px",
      "lineHeight": "1.4"
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontSize": "48px",
          "fontWeight": "700",
          "lineHeight": "1.05"
        },
        "spacing": {
          "margin": {
            "bottom": "0"
          }
        }
      },
      "core/site-tagline": {
        "typography": {
          "fontSize": "18px",
          "lineHeight": "1.3",
          "fontStyle": "italic"
        },
        "spacing": {
          "margin": {
            "top": "0"
          }
        }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "36px",
          "fontWeight": "700",
          "lineHeight": "1.15"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "18px",
          "lineHeight": "1.3"
        }
      },
      "core/button": {
        "border": {
          "radius": "0"
        },
        "elements": {
          "link": {
            "border": {
              "radius": "0"
            }
          }
        }
      }
    }
  }
}
