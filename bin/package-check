#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

echo "== Dirtbag package check =="

required=(style.css readme.txt license.txt screenshot.png theme.json templates/index.html languages/dirtbag.pot)
for file in "${required[@]}"; do
  [[ -f "$file" ]] || { echo "Missing required file: $file" >&2; exit 1; }
done

echo "Required files OK"

# Accept either form: the directory itself (`/playground export-ignore`, which git
# archive honours and which leaves no empty stub) or the glob (`playground/** ...`).
if ! grep -Eq '^/?playground(/\*\*)?[[:space:]]+export-ignore$' .gitattributes; then
  echo "playground/ must be export-ignored from release archives" >&2
  exit 1
fi

echo "Release archive exclusions OK"

python3 - <<'PY'
from pathlib import Path
import json, struct, re, sys
root = Path('.')

# JSON validation.
json_files = [Path('theme.json'), *sorted(Path('styles').glob('*.json')), *sorted(Path('playground').glob('*.json'))]
for p in json_files:
    json.loads(p.read_text())
print('JSON OK')

# Screenshot dimensions without Pillow.
with open('screenshot.png', 'rb') as f:
    sig = f.read(8)
    if sig != b'\x89PNG\r\n\x1a\n':
        raise SystemExit('screenshot.png is not a PNG')
    length = struct.unpack('>I', f.read(4))[0]
    chunk = f.read(4)
    if chunk != b'IHDR':
        raise SystemExit('screenshot.png missing IHDR')
    width, height = struct.unpack('>II', f.read(8))
    if (width, height) != (1200, 900):
        raise SystemExit(f'screenshot.png must be 1200x900, got {width}x{height}')
print('Screenshot OK')

# Block comment nesting in templates and parts.
comment_re = re.compile(r'<!--\s*(/)?wp:([A-Za-z0-9_\-/]+)(.*?)(/)?\s*-->', re.S)
for p in list(Path('templates').glob('*.html')) + list(Path('parts').glob('*.html')):
    stack = []
    for m in comment_re.finditer(p.read_text()):
        close, name, rest, selfclose = m.group(1), m.group(2), m.group(3), m.group(4)
        if close:
            if not stack or stack[-1] != name:
                raise SystemExit(f'{p}: closing {name} mismatches {stack[-1] if stack else "EMPTY"}')
            stack.pop()
        elif selfclose or rest.rstrip().endswith('/'):
            continue
        else:
            stack.append(name)
    if stack:
        raise SystemExit(f'{p}: unclosed blocks {stack}')
print('Block nesting OK')

# Package hygiene.
for p in root.rglob('*'):
    if '.git' in p.parts:
        continue
    rel = p.as_posix()
    name = p.name
    if any(part in {'.git', '.github', '.planning', 'tests', 'node_modules'} for part in p.parts):
        continue
    if p.is_file():
        if name in {'.DS_Store', 'Thumbs.db', 'desktop.ini', 'error_log', 'php.ini', 'web.config', 'favicon.ico'}:
            raise SystemExit(f'Forbidden file: {rel}')
        if p.suffix in {'.zip', '.sql', '.sh', '.xml'}:
            raise SystemExit(f'Forbidden package file type: {rel}')

root_forbidden = {'robots.txt','llms.txt','security.txt','about.txt','colophon.txt','feeds.txt','humans.txt','now.txt','blogroll.txt','blogroll.opml'}
for name in root_forbidden:
    if Path(name).exists():
        raise SystemExit(f'Site-root file must not be in theme package root: {name}')
if Path('.well-known').exists():
    raise SystemExit('.well-known must not be in the theme package root')
print('Package hygiene OK')

# Suspicious frontend/theme code.
scan_files = [*Path('templates').glob('*.html'), *Path('parts').glob('*.html'), *Path('patterns').glob('*.php'), Path('theme.json'), Path('style.css')]
patterns = [r'wp:html', r'<script', r'javascript:', r'\son[a-z]+\s*=']
for p in scan_files:
    text = p.read_text(errors='ignore')
    for pat in patterns:
        if re.search(pat, text, flags=re.I):
            raise SystemExit(f'Suspicious pattern {pat!r} in {p}')
print('Suspicious code scan OK')

# base64_decode is disallowed by WordPress.org Theme Check (obfuscation smell).
# Keep theme/demo PHP clean; data belongs in plain files (e.g. seed-content.json).
for p in [*Path('patterns').glob('*.php'), *Path('playground').glob('*.php')]:
    if 'base64_decode' in p.read_text(errors='ignore'):
        raise SystemExit(f'base64_decode found in {p} (not allowed; use a plain data file)')
print('No base64_decode OK')

# Reconcile guardrails: artifacts a raw Site-Editor export reintroduces and the
# reconcile step is supposed to strip. Fail loudly so they cannot slip back in.
reconcile_artifacts = {
    'core/post-data': 'invalid post-date datetime binding (no-op source)',
    '"theme":"dirtbag"': 'hardcoded theme slug in a template-part ref',
}
# Match real localhost/dev URLs, not the bare word "localhost" in prose.
localhost_url_re = re.compile(r'https?://localhost|localhost:\d')
def reconcile_hits(text):
    hits = [f'{snip!r} — {why}' for snip, why in reconcile_artifacts.items() if snip in text]
    if localhost_url_re.search(text):
        hits.append('absolute localhost/dev URL')
    return hits
for p in scan_files:
    hits = reconcile_hits(p.read_text(errors='ignore'))
    if hits:
        raise SystemExit(f'Reconcile artifact in {p}: {hits[0]}')
print('Reconcile guardrails OK')

# Malformed block delimiters (e.g. <\!-- from shell-mangled authoring).
malformed = '<\\!--'
for p in scan_files:
    if malformed in p.read_text(errors='ignore'):
        raise SystemExit(f'Malformed block delimiter {malformed!r} in {p}')

# Validate the Playground seed blob: the demo content is otherwise unchecked.
def _check_block_nesting(label, text):
    stack = []
    for m in comment_re.finditer(text):
        close, name, rest, selfclose = m.group(1), m.group(2), m.group(3), m.group(4)
        if close:
            if not stack or stack[-1] != name:
                raise SystemExit(f'{label}: closing {name} mismatches {stack[-1] if stack else "EMPTY"}')
            stack.pop()
        elif selfclose or rest.rstrip().endswith('/'):
            continue
        else:
            stack.append(name)
    if stack:
        raise SystemExit(f'{label}: unclosed blocks {stack}')

seed = Path('playground/seed-content.json')
if seed.exists():
    data = json.loads(seed.read_text(encoding='utf-8'))
    for post in data.get('posts', []):
        label = f"seed:{post.get('post_name')}"
        content = post.get('post_content', '')
        if malformed in content:
            raise SystemExit(f'Malformed block delimiter in {label}')
        _check_block_nesting(label, content)
        hits = reconcile_hits(content)
        if hits:
            raise SystemExit(f'Reconcile artifact in {label}: {hits[0]}')
    print('Seed content integrity OK')

# Image inventory: fail if wp.org package or Playground demo images drift.
image_exts = {'.png', '.jpg', '.jpeg', '.gif', '.webp', '.svg'}
allowed_theme_images = {
    'screenshot.png',
    'assets/icons/dirtbag-site-icon-white.png',
    'assets/icons/dirtbag-site-icon.png',
    'assets/icons/pickup-truck-header-white.svg',
    'assets/icons/pickup-truck-header.svg',
    'assets/icons/pickup-truck-white.svg',
    'assets/icons/pickup-truck.svg',
}
allowed_playground_images = {
    'playground/media/abandoned-rusty-ford-pickup.jpg',
    'playground/media/apostrophe-after-the-tag-workbench.png',
    'playground/media/deburring-machined-metal.jpg',
    'playground/media/whats-in-your-glove-box.jpg',
    'playground/media/secured-glovebox.jpg',
    'playground/media/blue-bird-truck-stop-sign.jpg',
    'playground/media/datsun-521-truck-1500.jpg',
    'playground/media/dirtbag-site-icon.png',
    'playground/media/driver-this-1975-van-watched.jpg',
    'playground/media/folding-table-and-chairs-green-2008.jpg',
    'playground/media/ford-cortina.jpg',
    'playground/media/highway-crossing-desert-sandoval-county.jpg',
    'playground/media/local-chapter-hall-veterans-foreign.jpg',
    'playground/media/old-truck-great-sand-dunes-colorado.jpg',
    'playground/media/potluck-la-catholique.jpg',
    'playground/media/red-pickup-truck.jpg',
    'playground/media/roadside-curio-shop-sign-1972.jpg',
    'playground/media/sunny-side-truck-stop-cafe.jpg',
    'playground/media/toyota-corona-mark-ii-double-pick.jpg',
    'playground/media/float-bug-context.png',
    'playground/media/float-bug-context-early.png',
    'playground/media/float-bug-symptom-purple.png',
}
actual_theme_images = set()
actual_playground_images = set()
for base in (Path('assets'),):
    if not base.exists():
        continue
    for p in base.rglob('*'):
        if p.is_file() and p.suffix.lower() in image_exts:
            actual_theme_images.add(p.as_posix())
if Path('screenshot.png').exists():
    actual_theme_images.add('screenshot.png')
if Path('playground/media').exists():
    for p in Path('playground/media').glob('*'):
        if p.is_file() and p.suffix.lower() in image_exts:
            actual_playground_images.add(p.as_posix())
if actual_theme_images != allowed_theme_images:
    extra = sorted(actual_theme_images - allowed_theme_images)
    missing = sorted(allowed_theme_images - actual_theme_images)
    raise SystemExit(f'Theme image inventory drift. Extra: {extra}; missing: {missing}')
if actual_playground_images != allowed_playground_images:
    extra = sorted(actual_playground_images - allowed_playground_images)
    missing = sorted(allowed_playground_images - actual_playground_images)
    raise SystemExit(f'Playground image inventory drift. Extra: {extra}; missing: {missing}')
print('Image inventory OK')

# No bundled frontend assets except required style.css and local images/SVGs.
for p in root.rglob('*'):
    if any(part in {'.git', '.github', '.planning', 'tests', 'node_modules'} for part in p.parts):
        continue
    if p.is_file() and p.suffix in {'.js', '.woff', '.woff2', '.ttf', '.otf'}:
        raise SystemExit(f'Unexpected bundled frontend asset: {p}')
for p in root.rglob('*.css'):
    if any(part in {'.git', '.github', '.planning', 'tests', 'node_modules'} for part in p.parts):
        continue
    if p.as_posix() != 'style.css':
        raise SystemExit(f'Unexpected CSS file: {p}')
print('Asset scan OK')

# i18n: pattern translation calls must use the 'dirtbag' text domain.
trans_re = re.compile(r"(?<![A-Za-z0-9_])(esc_html_e|esc_attr_e|esc_html__|esc_attr__|_e|__)\(\s*'(?:[^'\\]|\\.)*'\s*(?:,\s*'([^']*)')?\s*\)")
for p in Path('patterns').glob('*.php'):
    for m in trans_re.finditer(p.read_text()):
        if m.group(2) != 'dirtbag':
            raise SystemExit(f"i18n: {p}: text domain must be 'dirtbag' in {m.group(0)!r}")
print('i18n text domain OK')
PY

for file in functions.php patterns/*.php playground/*.php; do
  [[ -f "$file" ]] || continue
  php -l "$file" >/dev/null
done

echo "PHP syntax OK"
echo "All package checks passed."
