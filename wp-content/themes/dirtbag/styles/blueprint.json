{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Blueprint",
  "settings": {
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "name": "Blueprint",
          "slug": "blueprint",
          "color": "#000099"
        },
        {
          "name": "Line",
          "slug": "line",
          "color": "#ffffff"
        },
        {
          "name": "Cyan",
          "slug": "cyan",
          "color": "#00ffff"
        },
        {
          "name": "Shadow",
          "slug": "shadow",
          "color": "#000000"
        }
      ]
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 4,
        "mediumStep": 1.5,
        "unit": "rem"
      }
    },
    "custom": {
      "dirtbag": {
        "truckIconFilter": "brightness(0) saturate(100%) invert(64%) sepia(85%) saturate(1800%) hue-rotate(360deg) brightness(103%) contrast(105%)"
      }
    }
  },
  "styles": {
    "color": {
      "background": "#000099",
      "text": "#ffffff"
    },
    "elements": {
      "button": {
        "border": {
          "color": "#00ffff",
          "style": "solid",
          "width": "1px",
          "radius": "0"
        },
        "color": {
          "background": "#000099",
          "text": "#ffffff"
        },
        "spacing": {
          "padding": {
            "bottom": "0.5rem",
            "left": "0.75rem",
            "right": "0.75rem",
            "top": "0.5rem"
          }
        }
      },
      "caption": {
        "color": {
          "text": "#00ffff"
        },
        "typography": {
          "fontSize": "0.875rem"
        }
      },
      "link": {
        "color": {
          "text": "#00ffff"
        }
      }
    },
    "spacing": {
      "blockGap": "1rem",
      "padding": {
        "bottom": "2rem",
        "left": "1rem",
        "right": "1rem",
        "top": "2rem"
      }
    },
    "typography": {
      "fontFamily": "'Trebuchet MS', Helvetica, sans-serif"
    }
  }
}
