{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "preferredVersions": { "wp": "7.0", "php": "8.2" },
  "steps": [
    {
      "step": "installTheme",
      "themeData": {
        "resource": "git:directory",
        "url": "https://github.com/dknauss/dirtbag",
        "ref": "__REF__",
        "refType": "commit",
        "path": "/"
      },
      "options": { "activate": true, "targetFolderName": "dirtbag" },
      "ifAlreadyInstalled": "overwrite"
    },
    {
      "step": "runPHP",
      "code": "<?php require '/wordpress/wp-load.php'; require get_theme_file_path('playground/seed-content.php'); dirtbag_playground_seed_content();"
    }
  ]
}
