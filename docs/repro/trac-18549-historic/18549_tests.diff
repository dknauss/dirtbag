+	/**
+	 * Test that double quotes and apostrophes close correctly in the presence of inline html tags.
+	 *
+	 * @ticket 18549
+	 * @dataProvider data_inline_end_tags
+	 */
+	function test_inline_end_tags( $input, $output ) {
+		return $this->assertEquals( $output, wptexturize( $input ) );
+	}
+
+	function data_inline_end_tags() {
+		return array(
+			array(
+				'The word is "<a href="http://example.com/">quoted</a>".',
+				'The word is &#8220;<a href="http://example.com/">quoted</a>&#8221;.',
+			),
+			array(
+				'The word is \'<a href="http://example.com/">quoted</a>\'',
+				'The word is &#8216;<a href="http://example.com/">quoted</a>&#8217;',
+			),
+			array(
+				'The word is \'<a href="http://example.com/">quoted.</a>\'',
+				'The word is &#8216;<a href="http://example.com/">quoted.</a>&#8217;',
+			),
+			array(
+				'The word is \'<a href="http://example.com/">quoted</a>\'.',
+				'The word is &#8216;<a href="http://example.com/">quoted</a>&#8217;.',
+			),
+			array(
+				'The word is not \'<a href="http://example.com/">quot</a>\'d',
+				'The word is not &#8216;<a href="http://example.com/">quot</a>&#8217;d',
+			),
+			array(
+				'<em>John</em>\'s',
+				'<em>John</em>&#8217;s',
+			),
+			array(
+				'\'<em>John</em>\'s\'',
+				'&#8216;<em>John</em>&#8217;s&#8217;',
+			),
+			array(
+				'"<em>John</em>\'s"',
+				'&#8220;<em>John</em>&#8217;s&#8221;',
+			),
+			array(
+				'<em>"John"</em>\'s',
+				//'<em>&#8220;John&#8221;</em>&#8217;s', // Should be but...
+				'<em>&#8220;John&#8221;</em>&#8216;s', // Wrong: the ' in the stripped "John"'s seen as an opening single quote.
+			),
+			array(
+				'<em>\'John\'</em>\'s',
+				//'<em>&#8216;John&#8217;</em>&#8217;s', // Should be but...
+				'<em>&#8216;John&#8221;</em>s', // Wrong: the '' in the stripped 'John''s seen as a closing double tick quote.
+			),
+			array(
+				'<strong>Read more: </strong>"<a href="http://blah.com/test">Something (else)</a>"</p>',
+				'<strong>Read more: </strong>&#8220;<a href="http://blah.com/test">Something (else)</a>&#8221;</p>',
+			),
+
+		);
+	}
