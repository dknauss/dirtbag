+
+		// As replacements could interfere with later ones, treat each separately.
+		foreach ( $searches as $idx => $search_str ) {
+			if ( false !== ( $offset = strpos( $str, $search_str ) ) ) {
+				$repl_str = $repls[$idx];
+				$repl_len = strlen( $repl_str );
+				$len = strlen( $search_str );
