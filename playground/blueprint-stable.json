{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/",
  "meta": {
    "title": "Dirtbag Theme — Stable Tag",
    "author": "Dan Knauss",
    "description": "Preview the Dirtbag WordPress block theme pinned to the v0.1.9 release.",
    "categories": [
      "theme",
      "block-theme"
    ]
  },
  "preferredVersions": {
    "php": "8.3",
    "wp": "latest"
  },
  "login": true,
  "steps": [
    {
      "step": "installTheme",
      "themeData": {
        "resource": "git:directory",
        "url": "https://github.com/dknauss/dirtbag",
        "ref": "ccc08267ab024ece1a0e2d82de8285452b698a66",
        "refType": "commit",
        "path": "/"
      },
      "options": {
        "activate": true,
        "importStarterContent": true,
        "targetFolderName": "dirtbag"
      },
      "ifAlreadyInstalled": "overwrite"
    },
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "Dirtbag",
        "blogdescription": "Good bones and road grit."
      }
    },
    {
      "step": "runPHP",
      "code": "<?php\nrequire '/wordpress/wp-load.php';\nrequire get_theme_file_path( 'playground/seed-content.php' );\ndirtbag_playground_seed_content();\n"
    }
  ]
}
