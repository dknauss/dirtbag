{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Minimalist",
  "settings": {
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 4,
        "mediumStep": 1.5,
        "unit": "rem"
      }
    },
    "custom": {
      "dirtbag": {
        "truckIconFilter": "none"
      }
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#111111"
    },
    "elements": {
      "button": {
        "border": {
          "color": "#111111",
          "style": "solid",
          "width": "1px",
          "radius": "0"
        },
        "color": {
          "background": "#ffffff",
          "text": "#111111"
        },
        "spacing": {
          "padding": {
            "bottom": "0.5rem",
            "left": "0.75rem",
            "right": "0.75rem",
            "top": "0.5rem"
          }
        }
      },
      "caption": {
        "color": {
          "text": "#666666"
        },
        "typography": {
          "fontSize": "0.875rem"
        }
      },
      "link": {
        "color": {
          "text": "#111111"
        }
      }
    },
    "spacing": {
      "blockGap": "1rem",
      "padding": {
        "bottom": "2rem",
        "left": "1rem",
        "right": "1rem",
        "top": "2rem"
      }
    },
    "typography": {
      "fontFamily": "system-ui, sans-serif"
    }
  }
}
