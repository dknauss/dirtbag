{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/",
  "meta": {
    "title": "Dirtbag Theme \u2014 Main Branch",
    "author": "Dan Knauss",
    "description": "Preview the Dirtbag WordPress block theme from the main branch.",
    "categories": [
      "theme",
      "block-theme"
    ]
  },
  "preferredVersions": {
    "php": "8.3",
    "wp": "latest"
  },
  "login": true,
  "steps": [
    {
      "step": "installTheme",
      "themeData": {
        "resource": "url",
        "url": "https://wordpress-playground-cors-proxy.net/?https://github.com/dknauss/dirtbag/archive/refs/heads/main.zip"
      },
      "options": {
        "activate": true,
        "importStarterContent": true,
        "targetFolderName": "dirtbag"
      },
      "ifAlreadyInstalled": "overwrite"
    },
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "Dirtbag",
        "blogdescription": "Good bones and road grit."
      }
    },
    {
      "step": "runPHP",
      "code": "<?php\nrequire '/wordpress/wp-load.php';\nrequire get_theme_file_path( 'playground/seed-content.php' );\ndirtbag_playground_seed_content();\n"
    }
  ]
}
