{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Terminal",
  "settings": {
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "name": "Screen",
          "slug": "screen",
          "color": "#000000"
        },
        {
          "name": "Phosphor",
          "slug": "phosphor",
          "color": "#00ff00"
        },
        {
          "name": "Dim",
          "slug": "dim",
          "color": "#999999"
        },
        {
          "name": "Panel",
          "slug": "panel",
          "color": "#333333"
        }
      ]
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 4,
        "mediumStep": 1.5,
        "unit": "rem"
      }
    },
    "custom": {
      "dirtbag": {
        "truckIconFilter": "brightness(0) saturate(100%) invert(70%) sepia(98%) saturate(2400%) hue-rotate(80deg) brightness(115%) contrast(120%)"
      }
    }
  },
  "styles": {
    "color": {
      "background": "#000000",
      "text": "#00ff00"
    },
    "elements": {
      "button": {
        "border": {
          "color": "#00ff00",
          "style": "solid",
          "width": "1px",
          "radius": "0"
        },
        "color": {
          "background": "#000000",
          "text": "#00ff00"
        },
        "spacing": {
          "padding": {
            "bottom": "0.5rem",
            "left": "0.75rem",
            "right": "0.75rem",
            "top": "0.5rem"
          }
        }
      },
      "caption": {
        "color": {
          "text": "#999999"
        },
        "typography": {
          "fontSize": "0.875rem"
        }
      },
      "link": {
        "color": {
          "text": "#00ff00"
        }
      }
    },
    "spacing": {
      "blockGap": "1rem",
      "padding": {
        "bottom": "2rem",
        "left": "1rem",
        "right": "1rem",
        "top": "2rem"
      }
    },
    "typography": {
      "fontFamily": "'Lucida Console', Monaco, monospace"
    }
  }
}
