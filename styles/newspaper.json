{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Newspaper",
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "name": "Paper",
          "slug": "paper",
          "color": "#ffffff"
        },
        {
          "name": "Ink",
          "slug": "ink",
          "color": "#000000"
        },
        {
          "name": "Muted",
          "slug": "muted",
          "color": "#666666"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#990000"
        }
      ]
    },
    "layout": {
      "contentSize": "42rem",
      "wideSize": "64rem"
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 4,
        "mediumStep": 1.5,
        "unit": "rem"
      }
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Arial",
          "slug": "arial",
          "fontFamily": "Arial, Helvetica, sans-serif"
        },
        {
          "name": "Arial Black",
          "slug": "arial-black",
          "fontFamily": "'Arial Black', Gadget, sans-serif"
        },
        {
          "name": "Comic Sans MS",
          "slug": "comic-sans-ms",
          "fontFamily": "'Comic Sans MS', cursive, sans-serif"
        },
        {
          "name": "Courier New",
          "slug": "courier-new",
          "fontFamily": "'Courier New', Courier, monospace"
        },
        {
          "name": "Georgia",
          "slug": "georgia",
          "fontFamily": "Georgia, serif"
        },
        {
          "name": "Impact",
          "slug": "impact",
          "fontFamily": "Impact, Charcoal, sans-serif"
        },
        {
          "name": "Lucida Console",
          "slug": "lucida-console",
          "fontFamily": "'Lucida Console', Monaco, monospace"
        },
        {
          "name": "Lucida Sans Unicode",
          "slug": "lucida-sans-unicode",
          "fontFamily": "'Lucida Sans Unicode', 'Lucida Grande', sans-serif"
        },
        {
          "name": "Palatino",
          "slug": "palatino",
          "fontFamily": "'Palatino Linotype', 'Book Antiqua', Palatino, serif"
        },
        {
          "name": "Tahoma",
          "slug": "tahoma",
          "fontFamily": "Tahoma, Geneva, sans-serif"
        },
        {
          "name": "Times New Roman",
          "slug": "times-new-roman",
          "fontFamily": "'Times New Roman', Times, serif"
        },
        {
          "name": "Trebuchet MS",
          "slug": "trebuchet-ms",
          "fontFamily": "'Trebuchet MS', Helvetica, sans-serif"
        },
        {
          "name": "Verdana",
          "slug": "verdana",
          "fontFamily": "Verdana, Geneva, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "fluid": false,
          "name": "Small",
          "size": "15px",
          "slug": "small"
        },
        {
          "fluid": false,
          "name": "Base",
          "size": "18px",
          "slug": "base"
        },
        {
          "fluid": false,
          "name": "Medium",
          "size": "22px",
          "slug": "medium"
        },
        {
          "fluid": false,
          "name": "Large",
          "size": "28px",
          "slug": "large"
        },
        {
          "fluid": false,
          "name": "Extra Large",
          "size": "36px",
          "slug": "x-large"
        },
        {
          "fluid": false,
          "name": "Huge",
          "size": "48px",
          "slug": "huge"
        }
      ],
      "fluid": false
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#000000"
    },
    "elements": {
      "button": {
        "border": {
          "color": "#990000",
          "style": "solid",
          "width": "1px",
          "radius": "0"
        },
        "color": {
          "background": "#ffffff",
          "text": "#000000"
        },
        "spacing": {
          "padding": {
            "bottom": "0.5rem",
            "left": "0.75rem",
            "right": "0.75rem",
            "top": "0.5rem"
          }
        },
        ":hover": {
          "border": {
            "radius": "0"
          }
        },
        ":focus": {
          "border": {
            "radius": "0"
          }
        }
      },
      "caption": {
        "color": {
          "text": "#666666"
        },
        "typography": {
          "fontSize": "0.875rem"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "36px",
          "lineHeight": "1.15"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "28px",
          "lineHeight": "1.2"
        }
      },
      "link": {
        "color": {
          "text": "#990000"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "22px",
          "lineHeight": "1.25"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "20px",
          "lineHeight": "1.3"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "18px",
          "lineHeight": "1.35"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "15px",
          "lineHeight": "1.35"
        }
      }
    },
    "spacing": {
      "blockGap": "1rem",
      "padding": {
        "bottom": "2rem",
        "left": "1rem",
        "right": "1rem",
        "top": "2rem"
      }
    },
    "typography": {
      "fontFamily": "Georgia, serif",
      "fontSize": "18px",
      "lineHeight": "1.4"
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontSize": "48px",
          "fontWeight": "700",
          "lineHeight": "1.05"
        },
        "spacing": {
          "margin": {
            "bottom": "0"
          }
        }
      },
      "core/site-tagline": {
        "typography": {
          "fontSize": "18px",
          "lineHeight": "1.3",
          "fontStyle": "italic"
        },
        "spacing": {
          "margin": {
            "top": "0"
          }
        }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "36px",
          "fontWeight": "700",
          "lineHeight": "1.15"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "18px",
          "lineHeight": "1.3"
        }
      },
      "core/button": {
        "border": {
          "radius": "0"
        },
        "elements": {
          "link": {
            "border": {
              "radius": "0"
            }
          }
        }
      }
    },
    "css": "/* Dirtbag state layer: native controls, loud focus, no JavaScript. */\na:visited { color: #660066; }\na:hover,\na:focus { color: #ffffff; background: #000000; outline: 2px solid #990000; outline-offset: 2px; }\na:focus-visible { outline: 3px solid #990000; outline-offset: 3px; }\na:active { color: #ff0000; }\nbutton,\ninput,\ntextarea,\nselect,\n.wp-block-button__link { color: #000000; background: #ffffff; border: 1px solid #000000; border-radius: 0; }\nbutton:hover,\nbutton:focus,\ninput[type=button]:hover,\ninput[type=button]:focus,\ninput[type=submit]:hover,\ninput[type=submit]:focus,\n.wp-block-button__link:hover,\n.wp-block-button__link:focus { color: #ffffff; background: #000000; outline: 2px solid #990000; outline-offset: 2px; }\nbutton:focus-visible,\ninput:focus-visible,\ntextarea:focus-visible,\nselect:focus-visible,\n.wp-block-button__link:focus-visible { outline: 3px solid #990000; outline-offset: 3px; }\nbutton:active,\ninput[type=button]:active,\ninput[type=submit]:active,\n.wp-block-button__link:active { color: #ff0000; }\nbutton:disabled,\ninput:disabled,\ntextarea:disabled,\nselect:disabled { color: #666666; background: #cccccc; cursor: not-allowed; }\ninput:invalid,\ntextarea:invalid,\nselect:invalid { border-color: #ff0000; }\n.wp-block-navigation a[aria-current=page] { color: #000000; background: #cccccc; font-weight: 700; text-decoration: underline; }\nsummary:hover,\nsummary:focus { color: #ffffff; background: #000000; outline: 2px solid #990000; outline-offset: 2px; }"
  }
}
